{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of Docmost replicas"
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "tag": {
          "type": "string"
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer"
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "annotations": {
          "type": "object"
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string"
              },
              "paths": {
                "type": "array"
              }
            },
            "required": ["host", "paths"]
          }
        },
        "tls": {
          "type": "array"
        }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "appUrl": {
          "type": "string",
          "description": "Application URL"
        },
        "storage": {
          "type": "object",
          "properties": {
            "driver": {
              "type": "string",
              "enum": ["s3", "local"]
            },
            "fileUploadSizeLimit": {
              "type": "string"
            }
          }
        },
        "s3": {
          "type": "object",
          "properties": {
            "region": {
              "type": "string"
            },
            "bucket": {
              "type": "string"
            },
            "endpoint": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          }
        }
      },
      "required": ["appUrl"]
    },
    "secrets": {
      "type": "object",
      "properties": {
        "appSecret": {
          "type": "string",
          "minLength": 32,
          "description": "Application secret (minimum 32 characters)"
        },
        "databaseUrl": {
          "type": "string",
          "description": "PostgreSQL connection URL"
        },
        "redisUrl": {
          "type": "string",
          "description": "Redis connection URL"
        }
      },
      "required": ["appSecret", "databaseUrl", "redisUrl"]
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "required": ["config", "secrets"]
}
